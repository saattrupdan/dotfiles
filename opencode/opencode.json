{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "enabled_providers": [
    "llamacpp",
    "sparkie"
  ],
  "model": "llamacpp/qwen3-35B-A3B",
  "default_agent": "orchestrator",
  "agent": {
    "explore": {
      "disable": true
    }
  },
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Llama.cpp",
      "options": {
        "baseURL": "http://localhost:8080"
      },
      "models": {
        "qwen3-35B-A3B" : {
          "name": "Qwen3-35B-A3B"
        },
        "gemma-4-26B-A4B": {
          "name": "Gemma-4-26B-A4B"
        }
      }
    },
    "sparkie": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Sparkie",
      "options": {
        "baseURL": "http://spark-0774.local/api"
      },
      "models": {
        "google/gemma-4-26B-A4B-it": {
          "name": "Gemma-4-26B-A4B"
        }
      }
    }
  }
}
