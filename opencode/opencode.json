{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "enabled_providers": [
    "llamacpp",
    "sparkie",
    "internal-inference-server",
    "inference-server"
  ],
  "model": "llamacpp/qwen3.6-35B-A3B",
  "default_agent": "orchestrator",
  "agent": {
    "explore": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  },
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Llama.cpp",
      "options": {
        "baseURL": "http://localhost:8080"
      },
      "models": {
        "qwen3.5-35B-A3B" : {
          "name": "Qwen3.5-35B-A3B"
        },
        "qwen3.6-35B-A3B" : {
          "name": "Qwen3.6-35B-A3B"
        },
        "gemma-4-26B-A4B": {
          "name": "Gemma-4-26B-A4B"
        }
      }
    },
    "sparkie": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Sparkie",
      "options": {
        "baseURL": "http://192.168.0.28/api"
      },
      "models": {
        "google/gemma-4-26B-A4B-it": {
          "name": "Gemma-4-26B-A4B"
        }
      }
    },
    "inference-server": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Alexandra Inference Server",
      "options": {
        "baseURL": "https://inference.projects.alexandrainst.dk/v1"
      },
      "models": {
        "qwen-235b": {
          "name": "Qwen 235B"
        }
      }
    },
    "internal-inference-server": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Alexandra Internal Inference Server",
      "options": {
        "baseURL": "https://inference-test.projects.alexandrainst.dk/api"
      },
      "models": {
        "openai/gpt-oss-20b": {
          "name": "GPT-OSS-20B"
        }
      }
    }
  }
}
